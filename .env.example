# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USERS=123456789,987654321

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Vision model for receipt OCR
OPENROUTER_MODEL=openai/gpt-5-nano

# Text model for natural language queries — tool-use capable (defaults to OPENROUTER_MODEL if not set)
OPENROUTER_TEXT_MODEL=openai/gpt-5-nano
